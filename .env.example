# Add these to your .env file

# Etherscan API Key (Free tier: 100k calls/day)
# Get yours at: https://etherscan.io/myapikey
VITE_ETHERSCAN_API_KEY=YourApiKeyToken

# Solscan is currently public, but may need key in future
# VITE_SOLSCAN_API_KEY=optional

# Note: API keys prefixed with VITE_ are exposed to the browser
# This is OK for read-only blockchain APIs with free tiers
